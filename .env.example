# =============================================================
# DePIN Growth Platform — Environment Variables
# Copy to .env.local for local development.
# Never commit .env or .env.local to source control.
# =============================================================

# ---- App ----
NEXT_PUBLIC_APP_ENV=development          # development | staging | production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Analytics / On-chain ----
# Dune API key for on-chain analytics queries
DUNE_API_KEY=

# EVM RPC endpoints (public or private via Alchemy/Infura)
RPC_URL_ETHEREUM=https://eth.llamarpc.com
RPC_URL_BASE=https://mainnet.base.org
RPC_URL_ARBITRUM=https://arb1.arbitrum.io/rpc

# ---- Social / Distribution ----
# Twitter / X API credentials (OAuth 2.0)
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_BEARER_TOKEN=

# Farcaster Hub (Neynar)
NEYNAR_API_KEY=
NEYNAR_SIGNER_UUID=

# ---- CMS / Content ----
# Optional: Notion integration for content pipelines
NOTION_API_KEY=
NOTION_DATABASE_ID=

# ---- Vercel ----
# Auto-injected by Vercel — do not set manually
# VERCEL_ENV=production|preview|development
# VERCEL_URL=<auto-generated-url>
